from typing import List
import bisect

class Solution:
    def countNegatives(self, grid: List[List[int]]) -> int:
        count = 0

        for row in grid:
            # Binary search for first negative number
            left, right = 0, len(row)

            while left < right:
                mid = (left + right) // 2

                if row[mid] < 0:
                    right = mid
                else:
                    left = mid + 1

            # left is index of first negative
            count += len(row) - left

        return count
